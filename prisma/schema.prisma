generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── AUTH ────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts   Account[]
  sessions   Session[]
  portfolios Portfolio[]
  apiTokens  ApiToken[]
  cashAccounts   CashAccount[]
  cashCategories CashCategory[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model ApiToken {
  id        String    @id @default(cuid())
  userId    String
  name      String
  tokenHash String    @unique
  scope     String    @default("read")
  expiresAt DateTime?
  lastUsed  DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── PORTFOLIO ───────────────────────────────────────────────────────────────

model Portfolio {
  id                   String   @id @default(cuid())
  userId               String
  name                 String
  taxResidency         String   @default("AU")
  baseCurrency         String   @default("AUD")
  financialYearEnd     Int      @default(6)
  performanceMethod    String   @default("compound")
  taxEntityType        String   @default("individual")
  saleAllocationMethod String   @default("fifo")
  // Broker / account administrative details (optional, editable).
  brokerName     String?
  brokerWebsite  String?
  clientNumber   String?
  accountNumber  String?
  // Proposed 1 July 2027 CGT regime (Treasury Laws Amendment (Tax Reform No. 1)
  // Bill 2026 — not yet law). Opt-in projection settings. See
  // lib/calculations/cgt-2027.ts.
  cgtRegime              String   @default("current") // "current" | "proposed_2027"
  cgtTransitionMethod    String   @default("apportionment") // "market_value" | "apportionment"
  incomeSupportRecipient Boolean  @default(false) // exempt from the 30% minimum tax
  isForeignResident      Boolean  @default(false) // no CGT indexation / discount
  marginalTaxRate        Decimal? @db.Decimal(5, 4) // effective marginal rate on gains, e.g. 0.4700
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  holdings     Holding[]
  cashAccounts CashAccount[]
  shares       PortfolioShare[]
  importJobs   ImportJob[]
  fees         Fee[]
  accountLinks PortfolioAccount[]

  @@index([userId])
}

model PortfolioShare {
  id          String   @id @default(cuid())
  portfolioId String
  email       String
  accessLevel String   @default("read")
  createdAt   DateTime @default(now())

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, email])
}

// ─── HOLDINGS & TRANSACTIONS ─────────────────────────────────────────────────

model Holding {
  id           String   @id @default(cuid())
  portfolioId  String
  instrumentId String
  isCustom     Boolean  @default(false)
  drpEnabled   Boolean  @default(false)
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  portfolio    Portfolio      @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  instrument   Instrument     @relation(fields: [instrumentId], references: [id])
  transactions Transaction[]
  labels       HoldingLabel[]

  @@unique([portfolioId, instrumentId])
  @@index([portfolioId])
}

model Instrument {
  id               String    @id @default(cuid())
  code             String
  marketCode       String
  name             String
  instrumentType   String    @default("equity")
  country          String?
  sector           String?
  industry         String?
  currency         String    @default("AUD")
  faceValue        Decimal?  @db.Decimal(18, 6)
  couponRate       Decimal?  @db.Decimal(8, 4)
  paymentFrequency String?
  maturityDate     DateTime?
  creditRating     String?
  // CGT tax treatment override: "cgt" (shares/ETFs/listed debt & hybrids — CGT
  // events on disposal) or "income" (traditional non-listed bonds — CGT-exempt,
  // discount/premium is ordinary income). Null derives from instrumentType
  // (bond → income, otherwise cgt). See lib/calculations/asset-tax-class.ts.
  taxClass         String?
  isCustom         Boolean   @default(false)
  createdByUserId  String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  holdings Holding[]
  prices   Price[]
  info     InstrumentInfo?

  @@unique([code, marketCode])
  @@index([code])
}

/// Rich, periodically-refreshed market information for an instrument
/// (company profile, fundamentals, analyst views, news, financials, actions).
/// Fetched from Yahoo Finance via the Python yfinance backend.
model InstrumentInfo {
  id           String @id @default(cuid())
  instrumentId String @unique

  // Company profile
  longName  String?
  shortName String?
  summary   String? @db.Text
  website   String?
  sector    String?
  industry  String?
  country   String?
  city      String?
  employees Int?
  exchange  String?
  quoteType String?
  currency  String?

  // Frequently-displayed key stats (numeric)
  marketCap        Decimal? @db.Decimal(24, 2)
  trailingPE       Decimal? @db.Decimal(18, 4)
  forwardPE        Decimal? @db.Decimal(18, 4)
  priceToBook      Decimal? @db.Decimal(18, 4)
  beta             Decimal? @db.Decimal(12, 4)
  eps              Decimal? @db.Decimal(18, 4)
  dividendYield    Decimal? @db.Decimal(10, 6)
  fiftyTwoWeekHigh Decimal? @db.Decimal(18, 4)
  fiftyTwoWeekLow  Decimal? @db.Decimal(18, 4)

  // Rich structured data (JSON blobs)
  stats           Json? // additional key statistics
  analystTargets  Json? // {current, low, high, mean, median}
  recommendations Json? // analyst recommendation trend rows
  upgrades        Json? // recent upgrades/downgrades
  calendar        Json? // earnings dates, ex-dividend, estimates
  news            Json? // recent news items
  financials      Json? // income-statement summary by year
  actions         Json? // dividends + splits history

  fetchedAt DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  instrument Instrument @relation(fields: [instrumentId], references: [id], onDelete: Cascade)
}

model Transaction {
  id              String   @id @default(cuid())
  holdingId       String
  transactionType String
  tradeDate       DateTime
  quantity        Decimal  @db.Decimal(18, 6)
  price           Decimal  @db.Decimal(18, 6)
  brokerage       Decimal  @default(0) @db.Decimal(18, 2)
  exchangeRate    Decimal  @default(1) @db.Decimal(18, 6)
  currency        String   @default("AUD")
  comments        String?
  accruedInterest Decimal? @db.Decimal(18, 2)
  frankedAmount   Decimal? @db.Decimal(18, 2)
  unfrankedAmount Decimal? @db.Decimal(18, 2)
  frankingCredits Decimal? @db.Decimal(18, 2)
  taxDeferred     Decimal? @db.Decimal(18, 2)
  foreignTax      Decimal? @db.Decimal(18, 2)
  amitComponents  Json?
  importJobId     String?
  sourceId        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  holding   Holding    @relation(fields: [holdingId], references: [id], onDelete: Cascade)
  importJob ImportJob? @relation(fields: [importJobId], references: [id])
  reconciliations Reconciliation[]

  @@index([holdingId, tradeDate])
  @@index([holdingId, transactionType])
}

// ─── MARKET DATA ─────────────────────────────────────────────────────────────

model Price {
  id            String   @id @default(cuid())
  instrumentId  String
  date          DateTime @db.Date
  open          Decimal? @db.Decimal(18, 6)
  high          Decimal? @db.Decimal(18, 6)
  low           Decimal? @db.Decimal(18, 6)
  close         Decimal  @db.Decimal(18, 6)
  volume        BigInt?
  adjustedClose Decimal? @db.Decimal(18, 6)

  instrument Instrument @relation(fields: [instrumentId], references: [id], onDelete: Cascade)

  @@unique([instrumentId, date])
  @@index([instrumentId, date])
}

model ExchangeRate {
  id           String   @id @default(cuid())
  fromCurrency String
  toCurrency   String
  date         DateTime @db.Date
  rate         Decimal  @db.Decimal(18, 6)

  @@unique([fromCurrency, toCurrency, date])
  @@index([fromCurrency, toCurrency, date])
}

// Quarterly Consumer Price Index (All Groups), used for CGT cost-base indexation
// (current-law pre-1999 method and the proposed 2027 indexation regime) and for
// inflation-adjusted ("real") return reporting. Sourced from RBA Statistical
// Table G1. One row per CPI reference quarter.
model CpiIndex {
  id         String   @id @default(cuid())
  quarterEnd DateTime @db.Date // last day of the reference quarter (e.g. 1999-09-30)
  label      String // human label, e.g. "1999-Q3"
  indexValue Decimal  @db.Decimal(12, 4) // All Groups CPI index number
  source     String   @default("RBA G1")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([quarterEnd])
  @@index([quarterEnd])
}

// ─── IMPORT ──────────────────────────────────────────────────────────────────

model ImportJob {
  id              String    @id @default(cuid())
  portfolioId     String
  source          String
  status          String    @default("pending")
  fileName        String?
  mappingTemplate String?
  totalRows       Int       @default(0)
  importedRows    Int       @default(0)
  rejectedRows    Int       @default(0)
  errors          Json?
  createdAt       DateTime  @default(now())
  completedAt     DateTime?

  portfolio    Portfolio     @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  fees         Fee[]

  @@index([portfolioId])
}

model Fee {
  id            String    @id @default(cuid())
  portfolioId   String
  feeType       String    @default("custody")
  invoiceNumber String?
  invoiceDate   DateTime
  periodStart   DateTime?
  periodEnd     DateTime?
  chargeAmount  Decimal   @default(0) @db.Decimal(18, 2)
  gst           Decimal   @default(0) @db.Decimal(18, 2)
  total         Decimal   @db.Decimal(18, 2)
  currency      String    @default("AUD")
  comments      String?
  importJobId   String?
  createdAt     DateTime  @default(now())

  portfolio Portfolio  @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  importJob ImportJob? @relation(fields: [importJobId], references: [id])
  reconciliations Reconciliation[]

  @@index([portfolioId, invoiceDate])
}

model MappingTemplate {
  id         String   @id @default(cuid())
  userId     String
  name       String
  broker     String?
  mapping    Json
  dateFormat String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
}

// ─── ORGANISATION ────────────────────────────────────────────────────────────

model CustomGroup {
  id        String   @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime @default(now())

  categories CustomGroupCategory[]

  @@index([userId])
}

model CustomGroupCategory {
  id       String @id @default(cuid())
  groupId  String
  name     String
  holdings CustomGroupAssignment[]

  group CustomGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model CustomGroupAssignment {
  id           String @id @default(cuid())
  categoryId   String
  instrumentId String

  category CustomGroupCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, instrumentId])
}

model Label {
  id     String @id @default(cuid())
  userId String
  name   String

  holdings HoldingLabel[]

  @@unique([userId, name])
}

model HoldingLabel {
  holdingId String
  labelId   String

  holding Holding @relation(fields: [holdingId], references: [id], onDelete: Cascade)
  label   Label   @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([holdingId, labelId])
}

// ─── CASH ACCOUNTS ───────────────────────────────────────────────────────────

model CashAccount {
  id          String   @id @default(cuid())
  userId      String
  // Owning portfolio for VIRTUAL accounts and legacy migrated accounts. Physical
  // user accounts link to portfolios many-to-many via PortfolioAccount.
  portfolioId String?
  name        String
  institution String? // bank / platform name
  bsb         String? // AU 6-digit Bank-State-Branch (OFX BANKID)
  accountNumber String?
  accountType String   @default("transaction") // transaction|savings|offset|term_deposit|credit_card|cash
  // Virtual portfolio cash ledger: auto-maintained from portfolio transactions,
  // read-only, and excluded from total portfolio value (income still counts).
  isVirtual   Boolean  @default(false)
  currency    String   @default("AUD")
  openingBalance Decimal @default(0) @db.Decimal(18, 2)
  balance     Decimal  @default(0) @db.Decimal(18, 2) // cached current balance
  interestRate Decimal? @db.Decimal(8, 4)
  website     String?
  notes       String?
  archived    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  portfolio         Portfolio?         @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  transactions      CashTransaction[]  @relation("AccountTransactions")
  incomingTransfers CashTransaction[]  @relation("TransferCounterparty")
  cards             DebitCard[]
  portfolioLinks    PortfolioAccount[]

  @@index([userId])
  @@index([portfolioId])
}

model CashTransaction {
  id                String   @id @default(cuid())
  cashAccountId     String
  type              String
  amount            Decimal  @db.Decimal(18, 2) // positive magnitude; direction derived from type
  date              DateTime
  description       String?
  categoryId        String?
  // For transfer_in / transfer_out: the other cash account in the transfer.
  transferAccountId String?
  // Origin of the row: manual entry, statement import, portfolio auto-post, or accrued interest.
  source            String   @default("manual") // manual|import|portfolio|interest
  // OFX Financial Institution Transaction ID — stable id for idempotent import + reconciliation.
  fitId             String?
  // Dedup key for QIF/CSV rows lacking a FITID (date|amount|type|description hash).
  importHash        String?
  // Running balance reported on the statement, if provided.
  runningBalance    Decimal? @db.Decimal(18, 2)
  reconciled        Boolean  @default(false)
  importJobId       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @default(now()) @updatedAt

  cashAccount      CashAccount      @relation("AccountTransactions", fields: [cashAccountId], references: [id], onDelete: Cascade)
  transferAccount  CashAccount?     @relation("TransferCounterparty", fields: [transferAccountId], references: [id], onDelete: SetNull)
  category         CashCategory?    @relation(fields: [categoryId], references: [id])
  reconciliations  Reconciliation[]

  @@unique([cashAccountId, fitId])
  @@index([cashAccountId, date])
  @@index([cashAccountId, importHash])
  @@index([transferAccountId])
}

/// Debit / payment cards associated with a cash account.
model DebitCard {
  id            String   @id @default(cuid())
  cashAccountId String
  label         String?
  last4         String?
  network       String? // visa|mastercard|eftpos|amex
  expiry        String? // MM/YY
  createdAt     DateTime @default(now())

  cashAccount CashAccount @relation(fields: [cashAccountId], references: [id], onDelete: Cascade)

  @@index([cashAccountId])
}

/// Many-to-many link between portfolios and (physical) cash accounts. The default
/// link is the portfolio's settlement account for auto-posted cash movements.
model PortfolioAccount {
  id            String   @id @default(cuid())
  portfolioId   String
  cashAccountId String
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())

  portfolio   Portfolio   @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  cashAccount CashAccount @relation(fields: [cashAccountId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, cashAccountId])
  @@index([cashAccountId])
}

/// User-defined (and system) categories for personal-finance categorisation of
/// cash transactions.
model CashCategory {
  id       String  @id @default(cuid())
  userId   String
  name     String
  kind     String  @default("expense") // income|expense|transfer|investment|fee|interest
  color    String?
  parentId String?
  isSystem Boolean @default(false)
  createdAt DateTime @default(now())

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent       CashCategory?     @relation("CashCategoryTree", fields: [parentId], references: [id])
  children     CashCategory[]    @relation("CashCategoryTree")
  transactions CashTransaction[]

  @@index([userId])
}

/// Persistent link between an imported/auto-posted cash transaction and a portfolio
/// transaction or fee. Survives re-imports because cash transactions are keyed by
/// (cashAccountId, fitId) / importHash and never recreated.
model Reconciliation {
  id                String   @id @default(cuid())
  cashTransactionId String
  transactionId     String? // portfolio Transaction (buy/sell/dividend/interest/...)
  feeId             String? // portfolio custody Fee
  matchType         String   @default("manual") // auto|manual
  confidence        Float?
  createdAt         DateTime @default(now())

  cashTransaction CashTransaction @relation(fields: [cashTransactionId], references: [id], onDelete: Cascade)
  transaction     Transaction?    @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  fee             Fee?            @relation(fields: [feeId], references: [id], onDelete: SetNull)

  @@index([cashTransactionId])
  @@index([transactionId])
}

// ─── WATCHLIST ───────────────────────────────────────────────────────────────

model Watchlist {
  id     String @id @default(cuid())
  userId String
  name   String @default("Default")

  items WatchlistItem[]

  @@index([userId])
}

model WatchlistItem {
  id           String   @id @default(cuid())
  watchlistId  String
  instrumentId String
  notes        String?
  alertAbove   Decimal? @db.Decimal(18, 6)
  alertBelow   Decimal? @db.Decimal(18, 6)
  addedAt      DateTime @default(now())

  watchlist Watchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)

  @@unique([watchlistId, instrumentId])
}
