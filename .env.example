# Database (Neon Serverless PostgreSQL)
DATABASE_URL="postgresql://user:password@host/investalens?sslmode=require"
DIRECT_URL="postgresql://user:password@host/investalens?sslmode=require"

# Auth.js (generated by `npx auth secret`)
AUTH_SECRET="generate-with-npx-auth-secret"

# OAuth Providers (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Market Data
YAHOO_FINANCE_API_KEY=""
ALPHA_VANTAGE_API_KEY=""
OPEN_EXCHANGE_RATES_APP_ID=""

# AI Features (AI Import + AI Chat via Gemini)
GOOGLE_GENERATIVE_AI_API_KEY=""

# Cron Job Authentication
CRON_SECRET=""

# Analytics Service Shared Secret (protects /api/analytics; leave empty for local dev)
ANALYTICS_SHARED_SECRET=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
