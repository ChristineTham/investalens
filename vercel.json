{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": ["syd1"],
  "experimentalServices": {
    "web": {
      "entrypoint": ".",
      "routePrefix": "/",
      "framework": "nextjs"
    },
    "analytics": {
      "entrypoint": "api/analytics/app.py",
      "routePrefix": "/api/analytics",
      "maxDuration": 60
    }
  },
  "crons": [{ "path": "/api/cron/prices", "schedule": "0 8 * * 1-5" }]
}
